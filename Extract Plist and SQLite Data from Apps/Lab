Step 1.4: Identify Sensitive Data
Search for sensitive information:

# Find potential API keys in settings
sqlite3 sample_app/Documents/userdata.db "SELECT * FROM app_settings WHERE key LIKE '%key%' OR key LIKE '%token%';"

# Find messages containing sensitive keywords
sqlite3 sample_app/Documents/userdata.db "SELECT * FROM messages WHERE content LIKE '%key%' OR content LIKE '%password%' OR content LIKE '%token%';"

# Count records per table
sqlite3 sample_app/Documents/userdata.db "SELECT 'users' as table_name, COUNT(*) as count FROM users UNION SELECT 'messages', COUNT(*) FROM messages UNION SELECT 'app_settings', COUNT(*) FROM app_settings;"
